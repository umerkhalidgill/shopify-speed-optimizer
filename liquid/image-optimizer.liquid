
{% comment %}
Shopify Image Optimization Snippet
{% endcomment %}

<img
  src="{{ image | img_url: '800x' }}"
  srcset="
    {{ image | img_url: '400x' }} 400w,
    {{ image | img_url: '800x' }} 800w,
    {{ image | img_url: '1200x' }} 1200w
  "
  sizes="(max-width: 768px) 100vw, 800px"
  loading="lazy"
  alt="{{ image.alt | escape }}"
>
